# DB connection. Keep real credentials in .env only.
DB_CONFIG={
  "host": "your-db-host",
  "port": 5432,
  "user": "your-user",
  "password": "your-password",
  "database": "your-database"
}

# Optional crawler API keys.
ZENROWS_API_KEY=your_zenrows_api_key

# S3 backup settings.
AWS_REGION=ap-northeast-2
S3_BUCKET=your-s3-bucket
S3_PREFIX=retail_backup
S3_UPLOAD_RAW=1
S3_DELETE_EXTRA=0
S3_STORAGE_CLASS=STANDARD

# Common setting DB table names.
COMMON_TARGET_URL_TABLE=public.common_setting_step01_target_page_url
COMMON_OUTPUT_TABLE_REGISTRY=public.common_setting_step02_output_table
COMMON_RUN_PROFILE_TABLE=public.common_setting_step03_run_profile
